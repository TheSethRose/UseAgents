{
  "name": "@thesethrose/useagents",
  "version": "0.5.0",
  "description": "Local agent package runner for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "dev": "tsup src/index.ts --format esm --out-dir dist --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "smoke": "node dist/index.js --help && node dist/index.js search hello",
    "release:check": "npm run check && npm run build && npm run smoke && npm pack --dry-run",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "local",
    "runner"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSethRose/UseAgents.git"
  },
  "bugs": {
    "url": "https://github.com/TheSethRose/UseAgents/issues"
  },
  "homepage": "https://github.com/TheSethRose/UseAgents#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
