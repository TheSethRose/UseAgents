{
  "name": "@thesethrose/useagents",
  "version": "0.1.3",
  "description": "Local agent package runner for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "dev": "tsup src/index.ts --format esm --out-dir dist --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agents", "cli", "local", "runner"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesethrose/useagents.git"
  },
  "bugs": {
    "url": "https://github.com/thesethrose/useagents/issues"
  },
  "homepage": "https://github.com/thesethrose/useagents#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
